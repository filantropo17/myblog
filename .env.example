# MyBlog 全局环境变量模板
# 拷贝为根目录 `.env` 并按需修改
# 各 app 启动时会自动加载：根 .env → apps/<app>/.env（后者覆盖）

NODE_ENV=development

# === API 服务 ===
PORT=8787
# SQLite 数据库文件路径（相对 apps/api/）
DB_PATH=../../data/myblog.db

# AI API key — 鉴权用，仅校验 X-AI-API-Key 请求头
AI_API_KEY=dev-ai-key-change-me-in-production-12345

# === LLM（OpenAI 兼容，可选）===
# 仅作用于站内 AI 对话（/chat）
# 留空 → 对话走「FTS5 检索 + 模板」降级
# 填写 → 站内对话走真 LLM 流式回答
# 兼容：OpenAI / Anthropic(OpenAI-compatible proxy) / DeepSeek / Ollama / LM Studio
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_MS=30000

# === Admin 账号（首次启动时 seed） ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=myblog2026

# === CORS 允许的来源（逗号分隔）===
CORS_ORIGINS=http://localhost:4321,http://localhost:4322

# === Rate limit（每 IP 每分钟写操作上限）===
RATE_LIMIT_WRITES_PER_MINUTE=30

# === 作者信息 ===
# 启动时若 env 存在，会覆盖 settings 表里的对应字段
# 用于 /api/v1/settings/public 接口，前端通过它显示作者信息
AUTHOR_NAME=Your Name
AUTHOR_EMAIL=you@example.com
AUTHOR_GITHUB=https://github.com/yourname
