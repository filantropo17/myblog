# MyBlog API Environment
NODE_ENV=development
PORT=8787

# SQLite database file path
DB_PATH=../../data/myblog.db

# AI API key (rotatable) — 鉴权用，仅校验 X-AI-API-Key 请求头
AI_API_KEY=dev-ai-key-change-me-in-production-12345

# === LLM（OpenAI 兼容，可选）===
# 仅作用于站内 AI 对话（/chat）
# 留空 → 对话走「FTS5 检索 + 模板」降级（保留 2.0 行为）
# 填写 → 站内对话走真 LLM 流式回答
# 兼容：OpenAI / Anthropic(OpenAI-compatible proxy) / DeepSeek / Ollama / LM Studio 等
# 任意实现了 POST {base}/chat/completions 的端点都能用
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_MS=30000

# Admin auth (simple shared secret for demo)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=myblog2026

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:4321,http://localhost:4322

# Rate limit (writes per minute per IP)
RATE_LIMIT_WRITES_PER_MINUTE=30
