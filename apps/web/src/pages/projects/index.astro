---
import Layout from '../../layouts/Layout.astro';
import { ProjectCard } from '../../components/ProjectCard';
import { getProjects } from '../../lib/api-server';

const projects = await getProjects();
const statuses = ['active', 'planned', 'archived'] as const;

const labels = {
  active: '进行中',
  planned: '计划中',
  archived: '已归档',
};
---

<Layout title="项目 · MyBlog">
  <section class="relative pt-20 md:pt-32">
    <div class="mx-auto max-w-[1320px] px-6 md:px-10">
      <div class="mb-12 flex items-end justify-between gap-8">
        <div>
          <span class="eyebrow">项目展示</span>
          <h1 class="mt-6 font-display text-display-xl font-light tracking-[-0.04em] text-balance">
            副业项目，<span class="font-display-italic text-gradient">持续上线</span>。
          </h1>
          <p class="mt-8 max-w-2xl text-lg leading-relaxed text-[var(--ink-soft)] text-pretty">
            {projects.length} 个开源项目 / 实验性作品，从工具到玩具皆有。
            它们是工作的延伸，也是对工艺的好奇。
          </p>
        </div>
      </div>

      <!-- 过滤标签 -->
      <div class="mb-12 flex flex-wrap items-center gap-3 border-b border-[var(--border)] pb-4">
        <span class="eyebrow">筛选</span>
        <button class="btn btn-primary !py-1.5 !text-xs" data-cursor="hover">
          全部 <span class="ml-1 font-mono opacity-60">·</span> {projects.length}
        </button>
        {statuses.map((s) => {
          const count = projects.filter((p: any) => p.status === s).length;
          const colors = { active: '#10b981', planned: '#f59e0b', archived: '#9c8e72' };
          return (
            <button
              class="btn !py-1.5 !text-xs"
              style={`color: ${colors[s]}`}
              data-cursor="hover"
            >
              <span class="badge-dot" style={`background: ${colors[s]}`} />
              <span>{labels[s]}</span>
              <span class="font-mono opacity-60">·</span>
              <span>{count}</span>
            </button>
          );
        })}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1320px] px-6 pb-20 md:px-10">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((p: any, i: number) => (
        <ProjectCard project={p} index={i} client:visible />
      ))}
    </div>

    {projects.length === 0 && (
      <div class="py-32 text-center">
        <div class="eyebrow">空空如也</div>
        <p class="mt-4 font-display text-2xl text-[var(--ink-mute)]">暂无项目</p>
      </div>
    )}
  </section>
</Layout>
