---
import Layout from '../layouts/Layout.astro';
import { api, getPosts, getProjects, getSiteConfig, formatDate } from '../lib/api-server';
import { HomeHero } from '../components/HomeHero';
import { PostCard } from '../components/PostCard';
import { ProjectCard } from '../components/ProjectCard';

// SSR is off (static), but we can call the API at build time.
// Astro will warn if API is unreachable during build — that's fine, we
// fall back to local data.
let posts: any[] = [];
let projects: any[] = [];
let config: any = null;
try {
  posts = await getPosts();
  projects = await getProjects();
  config = await getSiteConfig();
} catch (e) {
  console.warn('API unreachable at build, using empty data', e);
}

const featured = posts[0];
const recent = posts.slice(1, 7);
const featuredProjects = projects.slice(0, 3);
---

<Layout title="MyBlog · 数字工坊 · 代码与设计">
  <HomeHero config={config} postsCount={posts.length} projectsCount={projects.length} client:load />

  <!-- 最新头条 -->
  {featured && (
    <section class="mx-auto max-w-[1320px] px-6 pb-16 pt-20 md:px-10 md:pt-28">
      <div class="mb-10 flex items-end justify-between gap-4">
        <div>
          <span class="eyebrow">最新发布</span>
          <h2 class="mt-3 font-display text-display-md font-light tracking-tight">
            最近<span class="font-display-italic text-[var(--accent)]">所思</span>。
          </h2>
        </div>
        <a href="/posts" class="hidden link-magnetic md:inline-flex text-sm font-medium text-[var(--ink-soft)] hover:text-[var(--accent)]">
          全部文章 →
        </a>
      </div>
      <PostCard post={featured} variant="feature" client:visible />
    </section>
  )}

  <!-- 近作网格 -->
  {recent.length > 0 && (
    <section class="mx-auto max-w-[1320px] px-6 py-16 md:px-10">
      <div class="mb-10 flex items-center justify-between">
        <span class="eyebrow">近期阅读</span>
        <span class="font-mono text-xs text-[var(--ink-mute)]">共 {recent.length} 篇</span>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {recent.map((p, i) => (
          <PostCard post={p} index={i} client:visible />
        ))}
      </div>
    </section>
  )}

  <!-- 精选项目 -->
  {featuredProjects.length > 0 && (
    <section class="mx-auto max-w-[1320px] px-6 py-24 md:px-10">
      <div class="mb-12 flex items-end justify-between gap-4">
        <div>
          <span class="eyebrow">精选作品</span>
          <h2 class="mt-3 font-display text-display-md font-light tracking-tight">
            持续运转的<span class="font-display-italic text-[var(--accent-2)]">副业项目</span>。
          </h2>
        </div>
        <a href="/projects" class="link-magnetic hidden text-sm font-medium text-[var(--ink-soft)] hover:text-[var(--accent)] md:inline-flex">
          全部项目 →
        </a>
      </div>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((p, i) => (
          <ProjectCard project={p} index={i} client:visible />
        ))}
      </div>
    </section>
  )}

  <!-- 数据条 -->
  <section class="mx-auto max-w-[1320px] px-6 py-16 md:px-10">
    <div class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--border)] md:grid-cols-4">
      {[
        { label: '文章', value: posts.length, suffix: '+' },
        { label: '项目', value: projects.length, suffix: '' },
        { label: '分类', value: 3, suffix: '' },
        { label: '阅读时长', value: '∞', suffix: '' },
      ].map((stat) => (
        <div class="bg-[var(--bg-soft)] p-8 md:p-12">
          <div class="font-display text-display-md font-light tracking-tight">
            <span class="text-gradient">{stat.value}</span>
            <span class="text-[var(--accent)]">{stat.suffix}</span>
          </div>
          <div class="mt-2 eyebrow">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- 宣言 -->
  <section class="mx-auto max-w-[1100px] px-6 py-32 text-center md:px-10">
    <span class="eyebrow">宣言</span>
    <blockquote class="mx-auto mt-8 max-w-4xl font-display text-3xl font-light leading-[1.2] tracking-tight text-balance md:text-6xl">
      <span class="text-[var(--ink-mute)]">"</span>
      prompt 是<span class="font-display-italic text-[var(--accent)]">需求</span>，
      diff 是<span class="font-display-italic text-[var(--accent-2)]">设计</span>，
      commit 是<span class="font-display-italic text-[var(--accent-3)]">产品</span>。
      <span class="text-[var(--ink-mute)]">"</span>
    </blockquote>
    <p class="mt-8 font-mono text-xs uppercase tracking-[0.2em] text-[var(--ink-mute)]">
      — Qianji Xiao · 2026
    </p>
  </section>
</Layout>
