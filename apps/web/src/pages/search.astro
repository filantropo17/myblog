---
/**
 * 搜索结果页。
 *
 * - 顶部搜索框（保留 query）
 * - 左侧筛选 + 右侧结果
 * - 高亮 <mark>
 */
import Layout from '../layouts/Layout.astro';

const apiBase = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:8787';
const url = new URL(Astro.request.url);
const q = url.searchParams.get('q') ?? '';
const type = url.searchParams.get('type') ?? 'all';
const tag = url.searchParams.get('tag') ?? '';
const category = url.searchParams.get('category') ?? '';

const res = q
  ? await fetch(
      `${apiBase}/api/v1/search?q=${encodeURIComponent(q)}&type=${type}&tag=${tag}&category=${category}&limit=20`
    ).catch(() => null)
  : null;
const json = res?.ok ? await res.json() : { data: { results: [], total: 0, facets: { tags: [], categories: [] } } };
const data = json.data ?? { results: [], total: 0, facets: { tags: [], categories: [] } };
---

<Layout title={q ? `搜索 · ${q}` : '搜索'} description="站内全文搜索">
  <section class="mx-auto max-w-[1320px] px-5 py-12 md:px-10 md:py-20">
    <header class="mb-10">
      <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--ink-mute)]">
        § SEARCH
      </p>
      <h1 class="mt-3 font-display text-3xl font-light tracking-tight md:text-5xl">
        站内<span class="text-gradient">搜索</span>
      </h1>

      <form action="/search" method="get" class="mt-6 flex items-center gap-3 rounded-2xl border border-[var(--border)] bg-[var(--bg-soft)] p-3 md:p-4">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-[var(--ink-mute)]">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input
          type="search"
          name="q"
          value={q}
          placeholder="输入关键词搜索 …"
          autocomplete="off"
          autofocus
          class="flex-1 bg-transparent text-lg outline-none placeholder:text-[var(--ink-mute)] md:text-xl"
        />
        {
          tag && <input type="hidden" name="tag" value={tag} />
        }
        <kbd class="hidden font-mono text-[10px] text-[var(--ink-mute)] md:inline">ESC</kbd>
      </form>
    </header>

    {
      q ? (
        <div class="grid gap-10 md:grid-cols-[220px_1fr]">
          {/* 左侧筛选 */}
          <aside class="space-y-6">
            <div>
              <h3 class="mb-3 font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--ink-mute)]">
                类型
              </h3>
              <ul class="space-y-1.5 text-sm">
                {[
                  { v: 'all', l: '全部' },
                  { v: 'post', l: '文章' },
                  { v: 'vibe', l: 'Vibe' },
                ].map((t) => (
                  <li>
                    <a
                      href={`/search?q=${q}&type=${t.v}`}
                      class:list={[
                        'flex items-center justify-between rounded-lg px-3 py-1.5 transition-colors',
                        type === t.v
                          ? 'bg-[var(--accent)]/10 text-[var(--accent)]'
                          : 'text-[var(--ink-mute)] hover:bg-[var(--bg-soft)]',
                      ]}
                    >
                      <span>{t.l}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            {data.facets.categories.length > 0 && (
              <div>
                <h3 class="mb-3 font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--ink-mute)]">
                  分类
                </h3>
                <ul class="space-y-1.5 text-sm">
                  {data.facets.categories.map((c: any) => (
                    <li>
                      <a
                        href={`/search?q=${q}&category=${c.slug}`}
                        class:list={[
                          'flex items-center justify-between rounded-lg px-3 py-1.5 transition-colors',
                          category === c.slug
                            ? 'bg-[var(--accent)]/10 text-[var(--accent)]'
                            : 'text-[var(--ink-mute)] hover:bg-[var(--bg-soft)]',
                        ]}
                      >
                        <span>{c.slug}</span>
                        <span class="font-mono text-[10px]">{c.count}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {data.facets.tags.length > 0 && (
              <div>
                <h3 class="mb-3 font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--ink-mute)]">
                  热门标签
                </h3>
                <ul class="flex flex-wrap gap-1.5">
                  {data.facets.tags.slice(0, 12).map((t: any) => (
                    <li>
                      <a
                        href={`/search?q=${q}&tag=${encodeURIComponent(t.slug)}`}
                        class="rounded-full border border-[var(--border)] px-3 py-1 font-mono text-[10px] transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
                      >
                        #{t.slug} <span class="opacity-60">{t.count}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </aside>

          {/* 右侧结果 */}
          <div>
            <p class="mb-6 font-mono text-xs text-[var(--ink-mute)]">
              找到 <span class="text-[var(--ink)]">{data.total}</span> 条结果 · 按相关度排序
            </p>

            {data.results.length === 0 ? (
              <div class="rounded-2xl border border-dashed border-[var(--border)] p-12 text-center">
                <p class="text-[var(--ink-mute)]">没有找到相关内容。</p>
                <p class="mt-2 font-mono text-[10px] text-[var(--ink-mute)]">
                  试试不同的关键词，或浏览热门标签。
                </p>
              </div>
            ) : (
              <ul class="space-y-6">
                {data.results.map((r: any) => (
                  <li>
                    <a
                      href={r.type === 'post' ? `/posts/${r.slug}` : `/vibe/${r.id}`}
                      class="group block rounded-2xl border border-[var(--border)] bg-[var(--bg-soft)]/50 p-5 transition-all hover:border-[var(--accent)]"
                      data-cursor="hover"
                    >
                      <div class="mb-2 flex items-center gap-2 font-mono text-[10px] uppercase tracking-wider text-[var(--ink-mute)]">
                        <span class="rounded-full border border-[var(--border-strong)] px-2 py-0.5">
                          {r.type === 'post' ? '文章' : 'Vibe'}
                        </span>
                        {r.category && <span>{r.category}</span>}
                        {r.mood && <span>· {r.mood}</span>}
                      </div>
                      <h3
                        class="mb-2 font-display text-xl font-medium tracking-tight transition-colors group-hover:text-[var(--accent)]"
                        set:html={r.title}
                      />
                      <p
                        class="text-sm leading-relaxed text-[var(--ink-mute)]"
                        set:html={r.excerpt}
                      />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ) : (
        <p class="text-[var(--ink-mute)]">输入关键词开始搜索。</p>
      )
    }
  </section>
</Layout>

<style is:global>
  :global(mark) {
    background: color-mix(in srgb, var(--accent) 25%, transparent);
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
  }
</style>