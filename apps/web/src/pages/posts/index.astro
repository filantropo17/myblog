---
import Layout from '../../layouts/Layout.astro';
import { PostCard } from '../../components/PostCard';
import { getPosts, getTags } from '../../lib/api-server';

const posts = await getPosts();
const tags = await getTags();

// 按年份分组，按编辑风排版
const byYear = new Map<number, any[]>();
for (const p of posts) {
  const y = new Date(p.publishedAt ?? p.createdAt).getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<Layout title="文章 · MyBlog">
  <!-- Hero -->
  <section class="relative pt-20 md:pt-32">
    <div class="mx-auto max-w-[1320px] px-6 md:px-10">
      <span class="eyebrow">文章索引</span>
      <h1 class="mt-6 font-display text-display-xl font-light tracking-[-0.04em] text-balance">
        所有<span class="font-display-italic text-gradient">文字，</span>
        按时间精心排列。
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-[var(--ink-soft)] text-pretty">
        共 {posts.length} 篇文章。
        关于设计、动画、TypeScript、AI 与个人工艺的碎片思考。
      </p>

      <!-- 标签云 -->
      {tags.length > 0 && (
        <div class="mt-12 flex flex-wrap items-center gap-2">
          <span class="eyebrow mr-2">主题</span>
          {tags.slice(0, 14).map((t) => (
            <a
              href={`/posts?tag=${encodeURIComponent(t.name)}`}
              class="group inline-flex items-center gap-1.5 rounded-full border border-[var(--border)] bg-[var(--bg-soft)] px-3 py-1.5 text-xs transition-all hover:border-[var(--accent)] hover:text-[var(--accent)]"
              data-cursor="hover"
            >
              <span class="font-medium">{t.name}</span>
              <span class="font-mono text-[10px] text-[var(--ink-mute)]">{t.count}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- 文章列表，按年份分组 -->
  <section class="mx-auto max-w-[1320px] px-6 py-20 md:px-10">
    {years.map((year) => (
      <div class="mb-20">
        <div class="mb-8 flex items-baseline gap-6 border-b border-[var(--border)] pb-4">
          <span class="font-display text-6xl font-light tracking-tight text-gradient md:text-8xl">
            {year}
          </span>
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--ink-mute)]">
            {byYear.get(year)!.length} 篇
          </span>
        </div>
        <div class="divide-y divide-[var(--border)]">
          {byYear.get(year)!.map((p, i) => (
            <PostCard post={p} index={i} variant="list" client:visible />
          ))}
        </div>
      </div>
    ))}
  </section>
</Layout>
