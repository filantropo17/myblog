---
import Layout from '../../layouts/Layout.astro';
import { MarkdownRenderer } from '../../components/MarkdownRenderer';
import CommentSection from '../../components/CommentSection';
import LikeButton from '../../components/LikeButton';
import ViewBeacon from '../../components/ViewBeacon';
import { getPost, getPosts, formatDate } from '../../lib/api-server';
import { renderMarkdown } from '../../lib/markdown';

const apiBase = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:8787';

export async function getStaticPaths() {
  let posts: any[] = [];
  try {
    posts = await getPosts();
  } catch {
    posts = [];
  }
  return posts.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect('/404');
}

const allPosts = await getPosts();
const idx = allPosts.findIndex((p) => p.slug === post.slug);
const prev = idx > 0 ? allPosts[idx - 1] : null;
const next = idx < allPosts.length - 1 ? allPosts[idx + 1] : null;

const catLabel = post.category === 'tech' ? '技术' : post.category === 'project' ? '项目' : '随笔';

// 在 SSR 阶段就把 markdown 渲染成 HTML，彻底解决"只有标题没正文"的客户端 hydration 问题
const { html: postHtml, headings: postHeadings } = await renderMarkdown(post.content ?? '');
---

<Layout title={post.title} description={post.seoDescription ?? post.excerpt ?? ''} ogImage={post.coverImageUrl}>
  <ViewBeacon
    targetType="post"
    targetId={post.id}
    path={`/posts/${post.slug}`}
    apiBase={apiBase}
    client:load
  />
  <!-- Hero -->
  <section class="relative pt-20 md:pt-32">
    <div class="mx-auto max-w-[920px] px-6 md:px-10">
      <a
        href="/posts"
        class="mb-8 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.18em] text-[var(--ink-mute)] transition-colors hover:text-[var(--accent)]"
        data-cursor="hover"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M11 18l-6-6 6-6" />
        </svg>
        <span>返回索引</span>
      </a>

      <div class="space-y-6">
        <div class="flex flex-wrap items-center gap-3">
          <span class="vt-eyebrow eyebrow">{catLabel}</span>
          <span class="font-mono text-xs text-[var(--ink-mute)]">·</span>
          <span class="font-mono text-xs text-[var(--ink-mute)]">{formatDate(post.publishedAt)}</span>
          <span class="font-mono text-xs text-[var(--ink-mute)]">·</span>
          <span class="font-mono text-xs text-[var(--ink-mute)]">阅读 {post.readingTime ?? 5} 分钟</span>
          <span class="font-mono text-xs text-[var(--ink-mute)]">·</span>
          <span class="font-mono text-xs text-[var(--ink-mute)] inline-flex items-center gap-1">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
              <circle cx="12" cy="12" r="3" />
            </svg>
            {(post.viewCount ?? 0) >= 100 ? `${((post.viewCount ?? 0)/1000).toFixed(1)}k` : (post.viewCount ?? 0)} 次阅读
          </span>
        </div>

        <h1 class="vt-title font-display text-display-lg font-light tracking-[-0.03em] text-balance">
          {post.title}
        </h1>

        {post.excerpt && (
          <p class="max-w-3xl font-display text-xl font-light italic leading-relaxed text-[var(--ink-soft)] text-pretty md:text-2xl">
            {post.excerpt}
          </p>
        )}
      </div>

      {post.coverImageUrl && (
        <figure class="vt-cover relative mt-12 overflow-hidden rounded-2xl border border-[var(--border)]">
          <img
            src={post.coverImageUrl}
            alt=""
            class="aspect-[2/1] w-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg)]/10 to-transparent" />
        </figure>
      )}

      {post.tags && post.tags.length > 0 && (
        <div class="mt-10 flex flex-wrap items-center gap-2 border-y border-[var(--border)] py-5">
          <span class="eyebrow mr-2">标签</span>
          {post.tags.map((t: string) => (
            <a
              href={`/posts?tag=${encodeURIComponent(t)}`}
              class="rounded-full border border-[var(--border)] bg-[var(--bg-soft)] px-3 py-1 font-mono text-[10px] uppercase tracking-wider text-[var(--ink-soft)] transition-all hover:border-[var(--accent)] hover:text-[var(--accent)]"
              data-cursor="hover"
            >
              #{t}
            </a>
          ))}
          <span class="ml-auto"><LikeButton targetType="post" targetId={post.id} apiBase={apiBase} initialCount={post.likeCount ?? 0} client:load /></span>
        </div>
      )}

      {/* 核心要点卡片 */}
      {post.keyPoints && post.keyPoints.length > 0 && (
        <details class="mt-8 rounded-2xl border border-[var(--border)] bg-[var(--bg-soft)]/40 p-5">
          <summary class="cursor-pointer list-none">
            <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--accent)]">
              ▾ 核心要点
            </span>
            <span class="ml-3 text-sm text-[var(--ink-mute)]">
              {post.keyPoints.length} 条 · {post.readingTime ?? 5} 分钟阅读
            </span>
          </summary>
          <ul class="mt-4 space-y-2 text-sm text-[var(--ink-soft)]">
            {post.keyPoints.map((p: string) => (
              <li class="flex gap-3">
                <span class="mt-1.5 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--accent)]" />
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </details>
      )}
    </div>
  </section>

  <!-- 正文 -->
  <section class="relative mx-auto max-w-[1320px] px-6 py-16 md:px-10">
    <MarkdownRenderer html={postHtml} headings={postHeadings} client:load />
  </section>

  <!-- 评论 -->
  <section class="relative mx-auto max-w-[860px] px-6 pb-20">
    <CommentSection
      targetType="post"
      targetId={post.id}
      apiBase={apiBase}
      client:load
    />
  </section>

  <!-- 上一篇 / 下一篇 -->
  {(prev || next) && (
    <section class="relative border-t border-[var(--border)]">
      <div class="mx-auto grid max-w-[1320px] gap-px overflow-hidden md:grid-cols-2">
        {prev && (
          <a
            href={`/posts/${prev.slug}`}
            class="group relative flex flex-col gap-2 bg-[var(--bg-soft)] p-8 transition-all hover:bg-[var(--bg-elev)] md:p-12"
            data-cursor="hover"
          >
            <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--ink-mute)]">
              ← 上一篇
            </span>
            <span class="font-display text-2xl font-medium tracking-tight transition-colors group-hover:text-[var(--accent)] md:text-3xl">
              {prev.title}
            </span>
          </a>
        )}
        {next && (
          <a
            href={`/posts/${next.slug}`}
            class="group relative flex flex-col gap-2 bg-[var(--bg-soft)] p-8 text-right transition-all hover:bg-[var(--bg-elev)] md:p-12"
            data-cursor="hover"
          >
            <span class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--ink-mute)]">
              下一篇 →
            </span>
            <span class="font-display text-2xl font-medium tracking-tight transition-colors group-hover:text-[var(--accent)] md:text-3xl">
              {next.title}
            </span>
          </a>
        )}
      </div>
    </section>
  )}
</Layout>
