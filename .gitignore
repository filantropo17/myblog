# =============================================================================
# Dependencies
# =============================================================================
node_modules/
.pnp
.pnp.js

# =============================================================================
# Build outputs
# =============================================================================
dist/
.astro/
.output/
.cache/
*.tsbuildinfo
.turbo/

# =============================================================================
# Environment files（任何位置，含根目录 + apps/*/）
# =============================================================================
.env
.env.local
.env.*.local
apps/*/.env
apps/*/.env.local

# 唯一允许进仓库的 .env 模板
!.env.example
!apps/*/.env.example

# =============================================================================
# Database & user uploads
# =============================================================================
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
data/*.db.bak*
data/uploads/*
# 留空目录占位（保证 data/ 在 clone 下来的仓库里能 git clone 出来）
!data/.gitkeep
!data/uploads/.gitkeep

# =============================================================================
# IDE / Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Logs
# =============================================================================
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# 测试 & 调试产物
# =============================================================================
# 截图 / Playwright 产物
test-results/
playwright-report/
playwright/.cache/
scripts/_artifacts/
scripts/screenshots/

# 一次性调试脚本（probe / print / 临时 verify）不进仓库
scripts/probe-*.mjs
scripts/probe-*.cjs
scripts/print-*.mjs
scripts/print-*.cjs
# verify-* 是按需跑的端到端验证脚本，一次性使用——不作为仓库常驻资产
scripts/verify-*.mjs
scripts/verify-*.cjs

# =============================================================================
# 临时 / 备份
# =============================================================================
*.bak
*.tmp
*.orig
*.rej

# =============================================================================
# 项目内部文档 / 截图 / 临时数据（不进仓库）
# =============================================================================
# PRD / 设计文档
docs/
# Claude Code 自动记忆
memory/
# 视觉验证截图
screenshots/
# 临时 API 调试目录
tmp-api/
# 工具脚本产物
tmp/
